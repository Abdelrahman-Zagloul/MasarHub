{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],

    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Hangfire": "Warning",
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },

    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {Message:lj} {NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "../../Logs/log-.txt",
          "rollingInterval": "Day",
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 10,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {Message:lj} {Properties}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },

  "ConnectionStrings": {
    "DefaultConnection": "Data Source=DESKTOP-EE2VFAB\\SQLEXPRESS;Initial Catalog=MasarHub;Integrated Security=True;Trust Server Certificate=True;",
    "Redis": "localhost:6379"
  },
  "LocalizationSettings": {
    "SupportedCultures": [ "en", "ar" ],
    "DefaultCulture": "en",
    "ResourcesPath": "Localization",
    "CacheExpirationInHours": 168
  },
  "JWTSettings": {
    "SecretKey": "Add Your Secret Key Here",
    "Issuer": "localhost:",
    "Audience": "localhost:",
    "DurationInMinutes": 30
  },
  "DefaultUsersSettings": {
    "SeedDefaultUsers": false,
    "AdminEmail": "",
    "AdminPassword": "",
    "InstructorEmail": "",
    "InstructorPassword": "",
    "StudentEmail": "",
    "StudentPassword": ""
  },
  "RefreshTokenSettings": {
    "RefreshTokenLifetimeDays": 7,
    "RefreshTokenHashKey": "Add Your Refresh Token Hash Key Here"
  },
  "MailSettings": {
    "Email": "Add Your Email Here",
    "DisplayName": "Masar Hub",
    "Password": "Add Your Password Here",
    "Host": "smtp.gmail.com",
    "Port": 587
  },
  "TwilioSettings": {
    "AccountSID": "Add Your Account SID Here",
    "AuthToken": "Add Your Auth Token Here",
    "TwilioPhoneNumber": "Add Your Twilio Phone Number Here"
  },
  "FrontendUrlsSettings": {
    "BaseURL": "http://localhost:4200",
    "ConfirmEmailPath": " http://localhost:4200/auth/confirm-email",
    "ResetPasswordPath": " http://localhost:4200/auth/reset-password"
  },
  "CorsSettings": {
    "AllowedOrigins": [], // add your origins
    "AllowedMethods": [], // add your methods
    "AllowedHeaders": [], // add your headers
    "AllowCredentials": true
  },

  "ExternalAuthSettings": {
    "Google": {
      "ClientId": "google-client-id"
    },
    "GitHub": {
      // login link in forntend to get code => https://localhost:3000/auth/github/callback?code=your-client-id
      "ClientId": "github-client-id",
      "ClientSecret": "github-client-secret",
      "AuthorizeUrl": "https://github.com/login/oauth/authorize",
      "TokenUrl": "https://github.com/login/oauth/access_token",
      "UserUrl": "https://api.github.com/user",
      "UserEmailsUrl": "https://api.github.com/user/emails"
    },
    "LinkedIn": {
      //login link in frontend to get code => https://www.linkedin.com/oauth/v2/authorization?response_type=code&client_id=YOUR_CLIENT_ID,&redirect_uri=your-RedirectUrl&scope=openid%20profile%20email",
      "ClientId": "linkedIn-client-id",
      "ClientSecret": "linkedIn-client-secret",
      "RedirectUrl": "http://localhost:3000/callback",
      "TokenUrl": "https://www.linkedin.com/oauth/v2/accessToken",
      "UserInfoUrl": "https://api.linkedin.com/v2/userinfo"
    },
    "Facebook": {
      //login link in frontend to get code => https://www.facebook.com/v22.0/dialog/oauth?client_id=client_id&redirect_uri=RedirectUrl
      "ClientId": "facebook-client-id",
      "ClientSecret": "facebook-client-secret",
      "RedirectUri": "http://localhost:3000/callback",
      "TokenUrl": "https://graph.facebook.com/v22.0/oauth/access_token",
      "UserInfoUrl": "https://graph.facebook.com/me"
    }
  }
}